# 전력 이슈 뉴스 아카이브 설정 — 전부 선택(없으면 기본값으로 동작)

# 수집 모드: auto(차단시 mock 폴백) | on(강제 mock) | off(강제 라이브, Actions용)
NEWS_MOCK=auto

# 사이트 생성 폴더 (기본 site/)
# NEWS_SITE_DIR=site

# 이전 아카이브 폴더 — Actions에서 gh-pages 체크아웃 경로로 주입됨 (로컬은 비움)
# NEWS_PREV_DIR=

# 카테고리별 최대 기사 수 (기본 14)
# NEWS_PER_CATEGORY=14
# 유사 기사(같은 사건·다른 매체) 제거 임계값 0~1 (기본 0.55, 높을수록 관대)
# NEWS_DEDUP_SIM=0.55

# ── 특허(Google Patents, 주간) — 출원인 × 분야 수집 ─────────────
# 수집 모드: auto | on(강제 mock) | off(강제 라이브, Actions용). 미설정 시 NEWS_MOCK 값을 따름
PATENT_MOCK=auto
# (출원인 × 분야) 조합마다 담을 최신 특허 수 (기본 6)
# PATENT_PER_PAIR=6
# 무키 엔드포인트 과속 방지용 요청 간 지연(초, 기본 0.2)
# PATENT_REQ_DELAY=0.2
# 주요 출원인 목록·분야 키워드는 patent_config.py 의 APPLICANTS / CATEGORIES 에서 편집
