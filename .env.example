# 전력 이슈 뉴스 아카이브 설정 — 전부 선택(없으면 기본값으로 동작)

# 수집 모드: auto(차단시 mock 폴백) | on(강제 mock) | off(강제 라이브, Actions용)
NEWS_MOCK=auto

# 사이트 생성 폴더 (기본 site/)
# NEWS_SITE_DIR=site

# 이전 아카이브 폴더 — Actions에서 gh-pages 체크아웃 경로로 주입됨 (로컬은 비움)
# NEWS_PREV_DIR=

# 카테고리별 최대 기사 수 (기본 14)
# NEWS_PER_CATEGORY=14

# ── 특허(Google Patents, 주간) ──────────────────────────────
# 수집 모드: auto | on(강제 mock) | off(강제 라이브, Actions용). 미설정 시 NEWS_MOCK 값을 따름
PATENT_MOCK=auto
# 최근 며칠 공개 특허를 볼지 (기본 7 = 지난 1주)
# PATENT_LOOKBACK_DAYS=7
# 카테고리별 최대 특허 수 (기본 18)
# PATENT_PER_CATEGORY=18
