# 전력 이슈 뉴스 아카이브 설정 — 전부 선택(없으면 기본값으로 동작)

# 수집 모드: auto(차단시 mock 폴백) | on(강제 mock) | off(강제 라이브, Actions용)
NEWS_MOCK=auto

# 사이트 생성 폴더 (기본 site/)
# NEWS_SITE_DIR=site

# 이전 아카이브 폴더 — Actions에서 gh-pages 체크아웃 경로로 주입됨 (로컬은 비움)
# NEWS_PREV_DIR=

# 카테고리별 최대 기사 수 (기본 14)
# NEWS_PER_CATEGORY=14

# 사이트 제목/부제
# NEWS_SITE_TITLE=전력 이슈 뉴스 아카이브
# NEWS_SITE_TAGLINE=반도체 클러스터·AI 데이터센터·3대 메가프로젝트 시대의 전력 이슈를 매일 모읍니다
